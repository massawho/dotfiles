#!/usr/bin/env bash
set -euo pipefail

I3_THEMES="$HOME/.config/i3/themes"
I3_CONFIG="$HOME/.config/i3/config"
DUNST_CONFIG="$HOME/.config/dunst/dunstrc"
ROFI_THEMES="$HOME/.local/share/rofi/themes"
ROFI_CONFIG="$HOME/.config/rofi/config.rasi"

current=""
[ -f "$I3_THEMES/current" ] && current=$(cat "$I3_THEMES/current")

themes=$(ls "$I3_THEMES" | grep -v '^current$' | sort)

menu=$(for t in $themes; do
    if [ "$t" = "$current" ]; then
        echo "* $t"
    else
        echo "  $t"
    fi
done)

selected=$(echo "$menu" | rofi -dmenu -p "Theme" -i | sed 's/^[* ]*//')

[ -z "$selected" ] && exit 0
[ "$selected" = "$current" ] && exit 0

theme_file="$I3_THEMES/$selected"
[ ! -f "$theme_file" ] && { notify-send "Theme" "Theme file not found: $selected" --urgency=critical; exit 1; }

# Apply i3 theme — replace THEME_BEGIN...THEME_END block
theme_block=$(cat "$theme_file")
python3 - "$I3_CONFIG" "$theme_block" <<'EOF'
import sys, re

config_path = sys.argv[1]
new_block = sys.argv[2]

with open(config_path) as f:
    content = f.read()

pattern = r'(# THEME_BEGIN[^\n]*\n).*?(# THEME_END)'
replacement = r'\g<1>' + new_block + '\n' + r'\2'
updated = re.sub(pattern, replacement, content, flags=re.DOTALL)

with open(config_path, 'w') as f:
    f.write(updated)
EOF

# Apply dunst theme — parse i3 theme vars and update dunstrc
python3 - "$theme_file" "$DUNST_CONFIG" <<'EOF'
import sys, re

theme_path = sys.argv[1]
dunst_path = sys.argv[2]

colors = {}
with open(theme_path) as f:
    for line in f:
        m = re.match(r'set \$(\w+)\s+(#[0-9a-fA-F]+)', line.strip())
        if m:
            colors[m.group(1)] = m.group(2)

with open(dunst_path) as f:
    lines = f.readlines()

section = None
result = []
for line in lines:
    sec = re.match(r'\[(\w+)\]', line.strip())
    if sec:
        section = sec.group(1)

    if re.match(r'\s*background\s*=', line) and section and section.startswith('urgency'):
        line = re.sub(r'"#[0-9a-fA-F]+"', f'"{colors["darkgrey"]}"', line)
    elif re.match(r'\s*foreground\s*=', line) and section and section.startswith('urgency'):
        line = re.sub(r'"#[0-9a-fA-F]+"', f'"{colors["white"]}"', line)
    elif re.match(r'\s*frame_color\s*=', line):
        if section == 'urgency_critical':
            line = re.sub(r'"#[0-9a-fA-F]+"', f'"{colors["urgentred"]}"', line)
        else:
            line = re.sub(r'"#[0-9a-fA-F]+"', f'"{colors["mediumgrey"]}"', line)

    result.append(line)

with open(dunst_path, 'w') as f:
    f.writelines(result)
EOF

# Track current theme
echo "$selected" > "$I3_THEMES/current"

# Apply rofi theme
rofi_theme="$ROFI_THEMES/$selected.rasi"
if [ -f "$rofi_theme" ]; then
    echo "@theme \"$rofi_theme\"" > "$ROFI_CONFIG"
else
    echo "@theme \"$ROFI_THEMES/arc_dark_transparent_colors.rasi\"" > "$ROFI_CONFIG"
fi

# Reload i3 and restart dunst
i3-msg reload > /dev/null
pkill dunst || true
sleep 0.3
dunst &
sleep 0.3

notify-send "Theme" "Switched to $selected" --urgency=low
